<Window x:Class="TreeToCSV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TreeToCSV"
        mc:Ignorable="d"
        Title="TreeToCSV" 
        Icon="app_icon.ico"
        Height="650" Width="850" 
        MinWidth="650" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3"
        FontFamily="Segoe UI, Yu Gothic UI">

    <Window.Resources>
        <!-- カラーパレット -->
        <SolidColorBrush x:Key="AccentBrush" Color="#0067C0" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1875D2" />
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#005A9E" />
        <SolidColorBrush x:Key="AccentDisabledBrush" Color="#999999" />
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#D1D1D1" />
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#242424" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5C5C5C" />

        <!-- モダンテキストボックススタイル -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#8A8A8A"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- モダンボタンスタイル -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FDFDFD"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}" 
                                SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter" 
                                              Focusable="false" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#F5F5F5"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#B5B5B5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#E5E5E5"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#959595"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#F3F3F3"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E5E5E5"/>
                                <Setter Property="Foreground" Value="#A6A6A6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- プライマリ（青）ボタンスタイル -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}" 
                                SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter" 
                                              Focusable="false" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentPressedBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentDisabledBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentDisabledBrush}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ツリーノード用のデータテンプレート -->
        <HierarchicalDataTemplate DataType="{x:Type local:TreeNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,3">
                <!-- 三状態のチェックボックス -->
                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" 
                          IsThreeState="True" 
                          VerticalAlignment="Center" 
                          Margin="0,0,6,0"
                          Cursor="Hand"/>
                
                <!-- フォルダ／ファイルを示すアイコン -->
                <TextBlock x:Name="IconText" 
                           FontFamily="Segoe MDL2 Assets" 
                           FontSize="14"
                           VerticalAlignment="Center" 
                           Margin="0,1,6,0" 
                           Foreground="{StaticResource AccentBrush}"/>
                
                <!-- 要素名 -->
                <TextBlock Text="{Binding Name}" 
                           VerticalAlignment="Center" 
                           FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
            <HierarchicalDataTemplate.Triggers>
                <!-- IsDirectoryプロパティに応じたアイコン切り替え -->
                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                    <Setter TargetName="IconText" Property="Text" Value="&#xE8B7;"/> <!-- Folder Icon -->
                </DataTrigger>
                <DataTrigger Binding="{Binding IsDirectory}" Value="False">
                    <Setter TargetName="IconText" Property="Text" Value="&#xE7C3;"/> <!-- File Icon -->
                    <Setter TargetName="IconText" Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- ヘッダーとフォルダ選択エリア -->
            <RowDefinition Height="Auto"/>
            <!-- ツリービューエリア (可変) -->
            <RowDefinition Height="*"/>
            <!-- 出力設定とアクションエリア -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 対象フォルダ選択エリア -->
        <Border Grid.Row="0" 
                Background="#FFFFFF" 
                BorderBrush="#E5E5E5" 
                BorderThickness="1" 
                CornerRadius="8" 
                Padding="16" 
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="対象フォルダの選択" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextPrimaryBrush}" 
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" 
                             Text="{Binding SelectedPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBoxStyle}" 
                             IsReadOnly="True"
                             VerticalAlignment="Center" 
                             Height="34"
                             FontSize="12"/>
                    <Button Grid.Column="1" 
                            Content="参照..." 
                            Command="{Binding BrowseCommand}" 
                            Style="{StaticResource ModernButtonStyle}" 
                            Margin="8,0,0,0" 
                            Height="34" 
                            Padding="16,0"
                            VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 2. ツリービューエリア -->
        <Border Grid.Row="1" 
                Background="#FFFFFF" 
                BorderBrush="#E5E5E5" 
                BorderThickness="1" 
                CornerRadius="8" 
                Padding="12"
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" 
                           Text="フォルダ構造と除外設定 (チェックを外すとCSV出力から除外されます)" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextPrimaryBrush}" 
                           Margin="4,0,0,8"/>
                <TreeView Grid.Row="1" 
                          ItemsSource="{Binding TreeItems}" 
                          BorderThickness="0" 
                          Background="Transparent"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <!-- ツリービューのスタイルの調整（アイテムホバー時のデザインなど） -->
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/> <!-- 初期状態で開く -->
                            <Setter Property="Padding" Value="4,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TreeViewItem">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- トグルボタン (＞) -->
                                            <ToggleButton x:Name="Expander" 
                                                          ClickMode="Press" 
                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" 
                                                          Style="{StaticResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="Transparent" Width="16" Height="16">
                                                            <Path x:Name="Arrow" 
                                                                  Data="M 1,1 L 5,5 L 1,9" 
                                                                  HorizontalAlignment="Center" 
                                                                  SnapsToDevicePixels="false" 
                                                                  Stroke="#9E9E9E" 
                                                                  StrokeThickness="1.5" 
                                                                  VerticalAlignment="Center">
                                                                <Path.RenderTransform>
                                                                    <RotateTransform Angle="0" CenterX="3" CenterY="5"/>
                                                                </Path.RenderTransform>
                                                            </Path>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="true">
                                                                <Setter TargetName="Arrow" Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <RotateTransform Angle="45" CenterX="3" CenterY="5"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="true">
                                                                <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource AccentBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>

                                            <!-- コンテンツ表示領域 -->
                                            <Border x:Name="Bd" 
                                                    Grid.Column="1" 
                                                    Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                                    Padding="{TemplateBinding Padding}" 
                                                    CornerRadius="4"
                                                    SnapsToDevicePixels="true">
                                                <ContentPresenter x:Name="PART_Header" ContentSource="Header" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                            </Border>

                                            <!-- 子ノード表示領域 -->
                                            <ItemsPresenter x:Name="ItemsHost" Grid.Column="1" Grid.Row="1"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="false">
                                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                            <Trigger Property="HasItems" Value="false">
                                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="true">
                                                <Setter TargetName="Bd" Property="Background" Value="#E2EEF9"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="true"/>
                                                    <Condition Property="Selector.IsSelectionActive" Value="false"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>
        </Border>

        <!-- 3. 出力設定とアクションエリア -->
        <Border Grid.Row="2" 
                Background="#FFFFFF" 
                BorderBrush="#E5E5E5" 
                BorderThickness="1" 
                CornerRadius="8" 
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 出力設定チェックボックス -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="出力設定" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               Margin="0,0,0,8"/>
                    <CheckBox Content="ファイル名・フォルダ名をダブルクォーテーション (&quot;) で囲む" 
                              IsChecked="{Binding QuoteFields, Mode=TwoWay}"
                              Cursor="Hand"
                              FontSize="13"/>
                </StackPanel>

                <!-- CSV出力ボタン -->
                <Button Grid.Column="1" 
                        Content="CSV出力" 
                        Command="{Binding ExportCsvCommand}" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Height="40" 
                        Padding="28,0" 
                        VerticalAlignment="Center"
                        FontSize="14"/>
            </Grid>
        </Border>
    </Grid>
</Window>

